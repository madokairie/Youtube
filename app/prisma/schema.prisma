generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  blogs         Blog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models
enum BlogType {
  marketing
  beauty
}

model Blog {
  id             String            @id @default(cuid())
  userId         String
  name           String
  type           BlogType
  url            String?
  scPropertyId   String?
  gaPropertyId   String?
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles       Article[]
  keywordAnalyses KeywordAnalysis[]
  ctaSettings    CTASetting[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum ArticleStatus {
  draft
  outline
  generating
  review
  published
}

model Article {
  id              String           @id @default(cuid())
  blogId          String
  title           String?
  slug            String?
  status          ArticleStatus    @default(draft)
  targetKeyword   String?
  metaDescription String?          @db.Text
  outline         Json?
  content         String?          @db.Text
  wordCount       Int?
  seoScore        Int?
  publishedUrl    String?
  publishedAt     DateTime?
  blog            Blog             @relation(fields: [blogId], references: [id], onDelete: Cascade)
  platformContents PlatformContent[]
  faqs            FAQ[]
  internalLinksFrom InternalLink[] @relation("FromArticle")
  internalLinksTo   InternalLink[] @relation("ToArticle")
  rankTrackings   RankTracking[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum Platform {
  note
  x_long
  x_post
}

enum ContentStatus {
  draft
  published
}

model PlatformContent {
  id                    String        @id @default(cuid())
  articleId             String
  platform              Platform
  content               String        @db.Text
  cannibalizationScore  Int?
  status                ContentStatus @default(draft)
  scheduledAt           DateTime?
  article               Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

enum GapType {
  no_content
  low_rank
  competitor_only
  trending
}

enum Difficulty {
  easy
  medium
  hard
}

enum LeadPotential {
  high
  medium
  low
}

enum KeywordStatus {
  suggested
  selected
  in_progress
  completed
}

model KeywordAnalysis {
  id              String              @id @default(cuid())
  blogId          String
  keyword         String
  searchVolume    Int?
  currentRank     Int?
  difficulty      Difficulty?
  leadPotential   LeadPotential?
  gapType         GapType?
  status          KeywordStatus       @default(suggested)
  blog            Blog                @relation(fields: [blogId], references: [id], onDelete: Cascade)
  competitors     CompetitorAnalysis[]
  analyzedAt      DateTime            @default(now())
}

model CompetitorAnalysis {
  id                  String          @id @default(cuid())
  keywordAnalysisId   String
  rank                Int
  url                 String
  title               String?
  wordCount           Int?
  headings            Json?
  coOccurrenceWords   Json?
  metaDescription     String?         @db.Text
  hasFaqSchema        Boolean         @default(false)
  keywordAnalysis     KeywordAnalysis @relation(fields: [keywordAnalysisId], references: [id], onDelete: Cascade)
  analyzedAt          DateTime        @default(now())
}

model RankTracking {
  id          String   @id @default(cuid())
  articleId   String
  keyword     String
  rank        Int
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  trackedAt   DateTime @default(now())

  @@index([articleId, trackedAt])
}

enum CTAType {
  line
  mail_magazine
  consultation
  download
}

enum CTAPosition {
  middle
  end
  both
}

model CTASetting {
  id          String      @id @default(cuid())
  blogId      String
  type        CTAType
  position    CTAPosition @default(both)
  title       String
  description String?     @db.Text
  url         String
  isActive    Boolean     @default(true)
  blog        Blog        @relation(fields: [blogId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model FAQ {
  id        String  @id @default(cuid())
  articleId String
  question  String  @db.Text
  answer    String  @db.Text
  sortOrder Int     @default(0)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model InternalLink {
  id              String  @id @default(cuid())
  articleId       String
  targetArticleId String
  anchorText      String
  position        String?
  status          String  @default("suggested")
  fromArticle     Article @relation("FromArticle", fields: [articleId], references: [id], onDelete: Cascade)
  toArticle       Article @relation("ToArticle", fields: [targetArticleId], references: [id], onDelete: Cascade)
}
